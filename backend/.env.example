# Copy this file to backend/.env for local development.
# The backend loads backend/.env first and falls back to client/.env only for shared keys.
# Do not pass this file directly to Cloud Run with --env-vars-file.
# Cloud Run sets some variables like PORT automatically.

# Core app
NODE_ENV=development
PORT=10000
MONGODB_URI=mongodb://127.0.0.1:27017/designhub
JWT_SECRET=replace-with-a-long-random-secret
FRONTEND_URL=http://localhost:5173
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:8081

# Auth
ACCESS_TOKEN_TTL=7d
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_COOKIE_NAME=refreshToken
RESET_PASSWORD_URL=http://localhost:5173/reset-password
STAFF_EMAIL_DOMAIN=smvec.ac.in

# Demo user bootstrap
SEED_DEMO_USERS=false
SEED_DEMO_USERS_OVERWRITE_PASSWORDS=false
DEMO_USER_EMAIL=
DEMO_USER_PASSWORD=
DEMO_USER_NAME=Demo User
DEMO_USER_ROLE=designer
TREASURER_DEMO_EMAIL=treasurer.portal@designhub.com
TREASURER_DEMO_PASSWORD="Treasurer#R7m2!"
TREASURER_DEMO_NAME=Treasurer

# AI
OLLAMA_URL=http://localhost:11434/api/generate
GEMINI_API_KEY=
GEMINI_API_KEYS=
GOOGLE_API_KEY=
GEMINI_MODEL=models/gemini-2.5-flash-lite
GEMINI_MAX_HISTORY_MESSAGES=6
GEMINI_RATE_LIMIT_COOLDOWN_MS=60000
GEMINI_QUOTA_COOLDOWN_MS=1800000
GEMINI_AUTH_COOLDOWN_MS=21600000

# Upload limits
UPLOAD_MAX_BYTES=52428800
WORKING_UPLOAD_MAX_BYTES=2684354560
WORKING_UPLOAD_CHUNK_BYTES=16777216
TASK_DEDUPE_WINDOW_MS=120000

# Google Drive
GOOGLE_DRIVE_FOLDER_ID=
DRIVE_PUBLIC=true
DRIVE_DATE_FOLDERS=true
GOOGLE_DRIVE_OAUTH=false

# Google Drive service account credentials
# Prefer split env vars for deployment. Use \n escapes in GOOGLE_PRIVATE_KEY.
GOOGLE_PROJECT_ID=
GOOGLE_PRIVATE_KEY_ID=
GOOGLE_PRIVATE_KEY=
GOOGLE_CLIENT_EMAIL=

# Google Drive alternate credential inputs
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_SERVICE_ACCOUNT_BASE64=
GOOGLE_DRIVE_KEYFILE=

# Google Drive OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_REFRESH_TOKEN=
GOOGLE_ACCESS_TOKEN=
GOOGLE_DRIVE_TOKEN_PATH=credentials/drive-oauth-token.json
GOOGLE_DRIVE_OAUTH_TOKEN_JSON=
GOOGLE_DRIVE_OAUTH_TOKEN_BASE64=

# Google login
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:10000/api/auth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=

# Notifications and branding
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_ALLOW_SELF_SIGNED=false
GMAIL_SMTP_USER=
GMAIL_SMTP_PASS=
GMAIL_SMTP_FROM=
BRAND_NAME=DesignDesk
BRAND_PRIMARY_HEX="#34429D"
BRAND_PRIMARY_SOFT="#EEF1FF"
BRAND_LOGO_PATH=
BRAND_LOGO_URL=
EMAIL_TASK_LINK_TTL=30d

# Twilio / WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_DEFAULT_TO=
TWILIO_CHANNEL=sms
TWILIO_WHATSAPP_TEMPLATE_SID=
TWILIO_WHATSAPP_TEMPLATE_VARIABLES=
TWILIO_WHATSAPP_TEMPLATE_VARIABLES_RAW=
TWILIO_DEBUG=false
USE_WHATSAPP_SELENIUM=false
WHATSAPP_HEADLESS=true
DEBUG_WHATSAPP=false

# OTP provider
TWO_FACTOR_API_KEY=
TWOFACTOR_API_KEY=

# Access control
MAIN_DESIGNER_EMAIL=
MAIN_DESIGNER_EMAILS=
