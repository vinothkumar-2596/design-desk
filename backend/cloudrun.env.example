# Copy this file to backend/cloudrun.env for Cloud Run deployments.
# Do not include reserved Cloud Run variables such as PORT.

NODE_ENV=production
FRONTEND_URL=https://your-frontend-domain
FRONTEND_ORIGINS=https://your-frontend-domain
RESET_PASSWORD_URL=https://your-frontend-domain/reset-password

# Configure Google OAuth redirect URIs in Google Cloud Console credentials.
# Typical callbacks:
# - https://your-cloud-run-service-url/api/auth/google/callback
# - https://your-cloud-run-service-url/api/drive/callback (if Drive OAuth is enabled)

# Fill these only if you use the related integrations.
ACCESS_TOKEN_TTL=7d
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_COOKIE_NAME=refreshToken
STAFF_EMAIL_DOMAIN=smvec.ac.in

GOOGLE_DRIVE_OAUTH=false
GOOGLE_DRIVE_FOLDER_ID=
DRIVE_PUBLIC=true
DRIVE_DATE_FOLDERS=true

GOOGLE_PROJECT_ID=
GOOGLE_PRIVATE_KEY_ID=
GOOGLE_PRIVATE_KEY=
GOOGLE_CLIENT_EMAIL=

GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_SERVICE_ACCOUNT_BASE64=
GOOGLE_DRIVE_KEYFILE=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_ACCESS_TOKEN=
GOOGLE_DRIVE_TOKEN_PATH=
GOOGLE_DRIVE_OAUTH_TOKEN_JSON=
GOOGLE_DRIVE_OAUTH_TOKEN_BASE64=

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

SMTP_HOST=
